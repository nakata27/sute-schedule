# SUTE Schedule Environment Variables
# Copy this to .env.local for local development

# Application
DEBUG=false
HOST=0.0.0.0
PORT=3000

# Caching
USE_CACHE=true
CACHE_LIFETIME_HOURS=24

# Request settings
RATE_LIMIT_DELAY=1.0
MAX_RETRIES=3
REQUEST_TIMEOUT=10

# Logging
LOG_LEVEL=INFO

# For Vercel deployment, these are already set in vercel.json
# No need to add them to .env

