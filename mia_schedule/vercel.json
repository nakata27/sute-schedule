{
  "buildCommand": "pip install -r requirements.txt",
  "framework": "flask",
  "functions": {
    "app.py": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "DEBUG": "false",
    "USE_CACHE": "true",
    "CACHE_LIFETIME_HOURS": "24",
    "HOST": "0.0.0.0",
    "PORT": "3000"
  }
}

